        {
          "name": "Convertir USD a ARS",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Respuesta exitosa', () => pm.response.to.have.status(200));",
                "pm.test('Incluye tasa y resultado', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body.rate).to.be.a('number');",
                "  pm.expect(body.convertedAmount).to.be.a('number');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/exchange/convert?from=USD&to=ARS&amount=100"
          }
        },
        {
          "name": "Monedas soportadas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/exchange/currencies"
          }
        },
