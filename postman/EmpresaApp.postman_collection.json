{
  "info": {
    "name": "EmpresaApp API",
    "description": "Colección completa para probar la API de EmpresaApp.\n\n1. Ejecuta primero **Login** (carpeta Auth)\n2. El token se guarda automáticamente en la variable `token`\n3. Importa también el environment `EmpresaApp-Local.postman_environment.json`\n4. Asegúrate de que la app esté corriendo en http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth (público - sin token)",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.environment.set('token', json.token);",
                  "    console.log('Token guardado correctamente');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Registro",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"juan\",\n  \"email\": \"juan@empresa.com\",\n  \"password\": \"123456\",\n  \"rol\": \"EMPLEADO\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/registro"
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Listar productos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/productos"
          }
        },
        {
          "name": "Buscar producto por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/productos/1"
          }
        },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"PROD-001\",\n  \"nombre\": \"Laptop HP\",\n  \"descripcion\": \"Laptop 15 pulgadas\",\n  \"stock\": 10,\n  \"stockMinimo\": 5,\n  \"precio\": 850.00\n}"
            },
            "url": "{{baseUrl}}/api/productos"
          }
        },
        {
          "name": "Actualizar producto",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"PROD-001\",\n  \"nombre\": \"Laptop HP Pro\",\n  \"descripcion\": \"Modelo actualizado\",\n  \"stock\": 10,\n  \"stockMinimo\": 3,\n  \"precio\": 900.00\n}"
            },
            "url": "{{baseUrl}}/api/productos/1"
          }
        },
        {
          "name": "Eliminar producto",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/productos/1"
          }
        }
      ]
    },
